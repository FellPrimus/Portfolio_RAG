# ===================================
# Flask 서버 설정
# ===================================
FLASK_DEBUG=true

# ===================================
# LLM 제공자 및 모델 선택
# ===================================
LLM_PROVIDER=clovax  # clovax, claude, openai 중 선택
MODEL_NAME=HCX-007   # CLOVA: HCX-007, HCX-003 / Claude: claude-3-5-sonnet-20241022

# ===================================
# API 키 설정 (⚠️ 2개 필요)
# ===================================
# NAVER CLOVA Studio (LLM_PROVIDER=clovax 사용 시)
CLOVASTUDIO_API_KEY=your_llm_api_key_here              # LLM용 (질의응답)
CLOVASTUDIO_EMBEDDING_API_KEY=your_embedding_api_key_here  # 임베딩용 (문서 벡터화)

# Claude API 키 (LLM_PROVIDER=claude 사용 시)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API 키 (LLM_PROVIDER=openai 사용 시)
# OPENAI_API_KEY=your_openai_api_key_here

# ===================================
# 임베딩 설정
# ===================================
# Qwen3 Embedding & Reranker API (권장 - 고품질)
QWEN_API_KEY=your_qwen_api_key_here
QWEN_EMBEDDING_API_KEY=your_qwen_api_key_here  # 임베딩용 (QWEN_API_KEY와 동일 키 사용 가능)
QWEN_RERANKER_API_KEY=your_qwen_api_key_here   # 재순위화용 (QWEN_API_KEY와 동일 키 사용 가능)
QWEN_API_BASE_URL=https://namc-aigw.io.naver.com

# 임베딩 제공자 선택
EMBEDDING_PROVIDER=qwen  # qwen (권장), clova (고품질, 1024차원) 또는 huggingface (무료, 384차원)
EMBEDDING_MODEL=Qwen3-Embedding-8B

# HuggingFace 사용 시 (선택사항 - 무료)
# EMBEDDING_PROVIDER=huggingface
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# CLOVA Embedding 사용 시 (선택사항)
# EMBEDDING_PROVIDER=clova

# ===================================
# 벡터 스토어 설정
# ===================================
VECTOR_STORE_TYPE=faiss
FAISS_PERSIST_DIRECTORY=./data/faiss

# ===================================
# 청킹 설정 (Qwen3-Embedding-8B 최적화)
# ===================================
CHUNKING_DEFAULT_CHUNK_SIZE=1500
CHUNKING_DEFAULT_CHUNK_OVERLAP=300
CHUNKING_MIN_CHUNK_SIZE=200
CHUNKING_MAX_CHUNK_SIZE=3000
CHUNKING_HTML_CHUNK_SIZE=2000
CHUNKING_PDF_CHUNK_SIZE=1200
CHUNKING_EXCEL_CHUNK_SIZE=500

# ===================================
# RAG 파이프라인 설정
# ===================================
RAG_RETRIEVAL_K=5
RAG_RERANK_TOP_N=3
RAG_MAX_RETRIES=2
RAG_MIN_QUALITY_SCORE=0.6
RAG_QUALITY_WEIGHT_LENGTH=0.2
RAG_QUALITY_WEIGHT_GROUNDING=0.4
RAG_QUALITY_WEIGHT_DIRECTNESS=0.2
RAG_QUALITY_WEIGHT_RELEVANCE=0.2
RAG_MIN_ANSWER_LENGTH=200

# ===================================
# LLM 설정
# ===================================
LLM_PROVIDER=clovax
LLM_TEMPERATURE=0.2
LLM_CREATIVE_TEMPERATURE=0.5
LLM_MAX_TOKENS=2048
# 프롬프트 전략 선택
# - strict: 엄격한 제약, 할루시네이션 < 1%, 정보 없으면 답변 거부 많음
# - balanced: 균형잡힌 접근, 할루시네이션 < 5%, 유용한 답변 (권장) ⭐
# - few_shot: Few-Shot 예시, 할루시네이션 < 2%, 최고 품질 (토큰 많이 사용)
LLM_PROMPT_STRATEGY=balanced
# 모델명 설정 (카테고리별 LLM 선택에 사용)
LLM_DEFAULT_MODEL_NAME=gpt-5.2      # API/가이드 문서용 기본 모델
LLM_SECURE_MODEL_NAME=gpt-oss-120b  # 보안 모드 및 일반/스펙 문서용 모델

# ===================================
# 웹 검색 교차 검증 설정 (Tavily API)
# ===================================
# Tavily API 키 (https://tavily.com에서 발급)
TAVILY_API_KEY=tvly-your_api_key_here
WEB_SEARCH_API_KEY=tvly-your_api_key_here  # TAVILY_API_KEY와 동일

# 웹 검색 기능 설정
WEB_SEARCH_ENABLED=false                  # 전역 활성화 여부 (기본: 비활성화)
WEB_SEARCH_MAX_RESULTS=3                  # 최대 검색 결과 수
WEB_SEARCH_SEARCH_DEPTH=basic             # 검색 깊이: basic (빠름) / advanced (상세)
WEB_SEARCH_ANONYMIZE_QUERY=true           # 쿼리 익명화 (내부 정보 유출 방지)
WEB_SEARCH_ALLOWED_IN_SECURE_MODE=false   # 보안 모드에서 웹 검색 허용 여부

# 도메인 필터 (JSON 배열 형태)
# WEB_SEARCH_INCLUDE_DOMAINS=["docs.example.com"]  # 허용 도메인만 검색
# WEB_SEARCH_EXCLUDE_DOMAINS=["spam.com"]          # 특정 도메인 제외

# ===================================
# 임베딩 설정 (추가)
# ===================================
EMBEDDING_PROVIDER=qwen
EMBEDDING_MODEL_NAME=Qwen3-Embedding-8B
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32
EMBEDDING_CLOVA_RATE_LIMIT=1.0
EMBEDDING_QWEN_BASE_URL=https://namc-aigw.io.naver.com

# ===================================
# 웹 크롤링 설정
# ===================================
CRAWL_TIMEOUT=15000
CRAWL_WAIT_TIME=2000
CRAWL_VIEWPORT_WIDTH=1280
CRAWL_VIEWPORT_HEIGHT=800
CRAWL_HEADLESS=true

# ===================================
# 스트리밍 응답 설정
# ===================================
STREAM_CHUNK_SIZE=3
STREAM_DELAY=0.01
STREAM_PREVIEW_LENGTH=200

# ===================================
# 경로 설정
# ===================================
PATH_DATA_DIR=./data
PATH_FAISS_DIR=./data/faiss_web
PATH_FEEDBACK_DIR=./data/feedback
PATH_LEARNING_CACHE_PATH=./data/learning_cache.json
PATH_HTML_DIR=./html
PATH_DOCUMENTS_DIR=./documents

# ===================================
# UI 설정
# ===================================
UI_DEFAULT_CATEGORY_COLOR=#6366f1
UI_DEFAULT_CATEGORY_ICON=📁

# ===================================
# 앱 설정
# ===================================
DEBUG=true
HOST=0.0.0.0
PORT=5000

# ===================================
# 레거시 호환성 (기존 코드와의 호환을 위해 유지)
# ===================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
PROMPT_STRATEGY=balanced
MIN_QUALITY_SCORE=0.6
MAX_RETRIES=2
